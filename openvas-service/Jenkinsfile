/*
 * CI pipeline for the OV1 OpenVAS integration service.
 *
 * Stages:
 *   1. Install     — create a virtualenv and install all Python dependencies
 *   2. Test        — run the unit test suite with pytest (no live OpenVAS required)
 *   3. Build Image — build the Docker image; tag with the short commit SHA
 *   4. Push Image  — push to the registry (runs only on the main branch)
 *
 * Required Jenkins credentials:
 *   REGISTRY_CREDENTIALS_ID — Docker Hub / private registry username + password
 *
 * Required Jenkins global variables (or edit the constants below):
 *   REGISTRY      — e.g. "registry.example.com"
 *   IMAGE_NAME    — e.g. "ov1-service"
 */

pipeline {

    agent any

    /*
     * All stages execute inside the openvas-service directory, which is
     * where the Dockerfile and requirements.txt live.
     */
    environment {
        SERVICE_DIR   = 'openvas-service'
        REGISTRY      = 'registry.example.com'
        IMAGE_NAME    = 'ov1-service'
        IMAGE_TAG     = "${env.GIT_COMMIT?.take(7) ?: 'latest'}"
        FULL_IMAGE    = "${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
    }

    options {
        /*
         * Discard old builds automatically to conserve disk space.
         * Keeps the last 10 runs and no more than 30 days of history.
         */
        buildDiscarder(logRotator(numToKeepStr: '10', daysToKeepStr: '30'))
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        stage('Install') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                        python3 -m venv .venv
                        . .venv/bin/activate
                        pip install --upgrade pip --quiet
                        pip install -r requirements.txt --quiet
                    '''
                }
            }
        }

        stage('Test') {
            /*
             * Unit tests are fully self-contained — they rely on the XML
             * fixtures under app/tests/fixtures/ and do not require a live
             * OpenVAS socket or a reachable MrBenny instance.
             */
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                        . .venv/bin/activate
                        pytest app/tests/ \
                            --tb=short \
                            --junitxml=test-results.xml \
                            -v
                    '''
                }
            }
            post {
                always {
                    junit "${SERVICE_DIR}/test-results.xml"
                }
            }
        }

        stage('Build Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "docker build -t ${FULL_IMAGE} ."
                }
            }
        }

        stage('Push Image') {
            /*
             * Image publication is intentionally restricted to the main
             * branch so that feature branches can validate the build
             * without affecting the shared registry.
             */
            when {
                branch 'main'
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'REGISTRY_CREDENTIALS_ID',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login ${REGISTRY} \
                            -u "$DOCKER_USER" --password-stdin
                        docker push ${FULL_IMAGE}
                        docker logout ${REGISTRY}
                    '''
                }
            }
        }
    }

    post {
        /*
         * Clean the workspace after every run to prevent stale virtualenvs
         * or cached layers from accumulating on the agent.
         */
        always {
            cleanWs()
        }
        success {
            echo "Pipeline completed successfully — image: ${FULL_IMAGE}"
        }
        failure {
            echo "Pipeline failed. Check the test report and build log above."
        }
    }
}