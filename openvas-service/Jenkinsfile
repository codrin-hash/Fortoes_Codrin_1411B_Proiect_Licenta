/*
 * CI pipeline for the OV1 OpenVAS integration service.
 *
 * Triggered automatically on every commit via a GitHub webhook.
 * Runs the full unit test suite inside a python:3.12-slim container —
 * no live OpenVAS socket or MrBenny instance is required.
 */

pipeline {

    agent any

    environment {
        SERVICE_DIR = 'openvas-service'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10', daysToKeepStr: '30'))
        timeout(time: 15, unit: 'MINUTES')
    }

    stages {

        stage('Test') {
            /*
             * Runs inside python:3.12-slim as root so pip can write to its
             * cache directories without permission errors. reuseNode keeps
             * the checked-out workspace accessible inside the container.
             */
            agent {
                docker {
                    image 'python:3.12-slim'
                    reuseNode true
                    args '-u root'
                }
            }
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                        pip install --quiet -r requirements.txt
                        export PYTHONPATH=$(pwd)
                        pytest app/tests/ \
                            --tb=short \
                            --junitxml=test-results.xml \
                            -v
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${SERVICE_DIR}/test-results.xml"
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "All tests passed."
        }
        failure {
            echo "Tests failed. Check the report above."
        }
    }
}